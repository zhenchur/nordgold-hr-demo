{
  "name": "nordgold-hr-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src vite.config.ts",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"*.{html,md,json,js,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" \"*.{html,md,json,js,ts}\"",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@barba/core": "^2.10.3",
    "figma-squircle": "^1.1.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.15"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.14"
  }
}
